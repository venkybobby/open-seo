# Use the full Node image so workerd has a working CA trust store for outbound HTTPS.
FROM node:22

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
# Required so `cloudflare:workers` env() reads process.env when running under
# `vite preview` (i.e. workerd inside a plain Node container, not on Cloudflare).
ENV CLOUDFLARE_INCLUDE_PROCESS_ENV=true
# Building with showDevtools disabled keeps the bundle lean for production.
ENV VITE_SHOW_DEVTOOLS=false

# Build args that the client bundle reads via `import.meta.env.*`. These MUST
# be set at image-build time because Vite inlines them into the static JS.
# Setting them only at runtime (Railway/Koyeb Variables) is too late — the
# bundle is already frozen. Railway passes every service Variable as a build
# arg automatically; for local `docker build` use `--build-arg AUTH_MODE=...`.
#
#   AUTH_MODE          local_noauth | hosted | cloudflare_access (default: local_noauth)
#   POSTHOG_PUBLIC_KEY optional analytics
#   POSTHOG_HOST       optional analytics host
ARG AUTH_MODE=local_noauth
ARG POSTHOG_PUBLIC_KEY
ARG POSTHOG_HOST
ENV AUTH_MODE=${AUTH_MODE}
ENV POSTHOG_PUBLIC_KEY=${POSTHOG_PUBLIC_KEY}
ENV POSTHOG_HOST=${POSTHOG_HOST}

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.30.1 --activate

# Install deps first to maximize Docker layer cache hits.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy the rest of the sources and build at IMAGE-BUILD time, not runtime.
# This means the container boots in seconds (just migrate + start) instead of
# spending 5–10 minutes building on every redeploy. Without this, hosted PaaS
# (Railway/Koyeb) healthchecks race the build and return 404 from the edge
# proxy before the app ever binds to $PORT.
COPY . .
RUN pnpm run build

# Vite preview honors $PORT (Railway / Koyeb / Fly inject their own — typically
# 8080). For local `docker run` it falls back to 3001 via the shell expansion
# below. We deliberately DO NOT declare `EXPOSE 3001` because Railway uses
# EXPOSE as the target port for its edge proxy, which would mis-route traffic
# to 3001 when the app is actually listening on $PORT. Letting Railway/Koyeb
# auto-detect from the live listener is correct on every PaaS we support.

# Healthcheck hits the app via loopback. Long start-period gives D1 migrations
# room to run on first boot when the persistent volume is empty.
HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:'+(process.env.PORT||3001)+'/').then(r=>process.exit(r.status<500?0:1)).catch(()=>process.exit(1))"

# Only migrate + start at runtime. The build is already in /app/dist.
CMD ["sh", "-c", "pnpm run db:migrate:local && pnpm exec vite preview --host 0.0.0.0 --port ${PORT:-3001}"]
